# ============================================
# Ama a Dios — Proyecto Amor Conyugal
# Variables de Entorno
# ============================================
# Copia este archivo como .env.local y completa
# los valores según tu entorno.
#
#   cp .env.example .env.local
# ============================================

# --- Requeridas ---

# URL pública del sitio (sin barra al final)
# Ej: https://amaadios.org
NEXT_PUBLIC_SITE_URL=

# --- Opcionales ---

# Nombre del sitio (se usa en meta tags y Open Graph)
NEXT_PUBLIC_SITE_NAME=Ama a Dios — Proyecto Amor Conyugal

# Email de contacto que aparece en la página /contacto
CONTACT_EMAIL=info@amaadios.org

# --- Analytics (opcional) ---

# Google Analytics Measurement ID (opcional)
# Ej: G-XXXXXXXXXX
# NEXT_PUBLIC_GA_ID=
